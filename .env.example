# Backend secrets — copy to .env and fill in real values
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars

# Path to your exercise JSON + image data on the host machine
# Windows example: EXERCISE_DATA_PATH=C:\Users\you\exercise-data\exercises
# Mac/Linux example: EXERCISE_DATA_PATH=/home/you/exercise-data/exercises
EXERCISE_DATA_PATH=./exercise_data
